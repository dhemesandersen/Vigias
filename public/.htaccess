Options -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # ==========================================
  # BASE REGULAR EXPRESSION CONFIGURATION
  # Configured for root domain deployment (public_html)
  # ==========================================
  RewriteBase /
  
  # 301 Redirects for Old Pages (SEO Preservation)
  # 1. Main Language Roots and Indexes
  RewriteRule ^index\.(html|php|htm)$ pt/ [R=301,NC,L]
  RewriteRule ^(index|home|default)$ pt/ [R=301,NC,L]
  
  # 2. General Section Pages (Portuguese)
  RewriteRule ^casas/?(\.html|\.php)?$ pt/casas [R=301,NC,L]
  RewriteRule ^(envolvente|natureza)/?(\.html|\.php)?$ pt/envolvente [R=301,NC,L]
  RewriteRule ^(experiencias|experiência|experiencia)/?(\.html|\.php)?$ pt/experiencias [R=301,NC,L]
  RewriteRule ^reservas/?(\.html|\.php)?$ pt/reservas [R=301,NC,L]
  RewriteRule ^(vigias|nos|sobre|sustentabilidade|historia)/?(\.html|\.php)?$ pt/vigias [R=301,NC,L]
  RewriteRule ^(contacto|contactos)/?(\.html|\.php)?$ pt/contacto [R=301,NC,L]
  RewriteRule ^patrimonio/?(\.html|\.php)?$ pt/envolvente [R=301,NC,L]
  RewriteRule ^politica-de-privacidade/?(\.html|\.php)?$ pt/politica-de-privacidade [R=301,NC,L]
  
  # 3. Individual Casas (Portuguese)
  RewriteRule ^(casa-sol|casas/casa-sol|casas/sol)/?(\.html|\.php)?$ pt/casas/casa-sol [R=301,NC,L]
  RewriteRule ^(casa-gaio|casas/casa-gaio|casas/gaio)/?(\.html|\.php)?$ pt/casas/casa-gaio [R=301,NC,L]
  RewriteRule ^(casa-cal|casas/casa-cal|casas/cal)/?(\.html|\.php)?$ pt/casas/casa-cal [R=301,NC,L]
  RewriteRule ^(casa-feto|casas/casa-feto|casas/feto)/?(\.html|\.php)?$ pt/casas/casa-feto [R=301,NC,L]
  RewriteRule ^(casa-ocre|casas/casa-ocre|casas/ocre)/?(\.html|\.php)?$ pt/casas/casa-ocre [R=301,NC,L]
  
  # 4. English Section Pages
  RewriteRule ^houses\.(html|php)$ en/houses [R=301,NC,L]
  RewriteRule ^surroundings\.(html|php)$ en/surroundings [R=301,NC,L]
  RewriteRule ^experiences\.(html|php)$ en/experiences [R=301,NC,L]
  RewriteRule ^book\.(html|php)$ en/book [R=301,NC,L]
  RewriteRule ^about\.(html|php)$ en/about [R=301,NC,L]
  RewriteRule ^contact\.(html|php)$ en/contact [R=301,NC,L]
  
  # 5. Individual Houses (English)
  RewriteRule ^(house-sol|houses/sol)\.(html|php)$ en/houses/casa-sol [R=301,NC,L]
  RewriteRule ^(house-gaio|houses/gaio)\.(html|php)$ en/houses/casa-gaio [R=301,NC,L]
  RewriteRule ^(house-cal|houses/cal)\.(html|php)$ en/houses/casa-cal [R=301,NC,L]
  RewriteRule ^(house-feto|houses/feto)\.(html|php)$ en/houses/casa-feto [R=301,NC,L]
  RewriteRule ^(house-ocre|houses/ocre)\.(html|php)$ en/houses/casa-ocre [R=301,NC,L]
  
  # 6. Spanish Section Pages
  RewriteRule ^entorno\.(html|php)$ es/entorno [R=301,NC,L]
  RewriteRule ^es/casas\.(html|php)$ es/casas [R=301,NC,L]
  RewriteRule ^es/experiencias\.(html|php)$ es/experiencias [R=301,NC,L]
  RewriteRule ^es/reservas\.(html|php)$ es/reservas [R=301,NC,L]
  RewriteRule ^es/vigias\.(html|php)$ es/vigias [R=301,NC,L]
  RewriteRule ^es/contacto\.(html|php)$ es/contacto [R=301,NC,L]

  # Prevent rewriting of static asset files entirely to preserve caching headers
  RewriteRule \.(js|css|gif|jpe?g|png|ico|svg|woff2?|webp|pdf|txt)$ - [L]
  
  # Serve physical files directly
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l
  
  # Absolute rewrite rule to target the core index.html on the root folder
  RewriteRule ^(.*)$ index.html [L]
</IfModule>

# Definitive fallback for 404 errors (essential for LiteSpeed / Hostinger)
ErrorDocument 404 /index.html

# Disable caching for index.html (both browsers and servers like LiteSpeed/Hostinger cache)
<FilesMatch "\.(html|htm)$">
  <IfModule mod_headers.c>
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
  </IfModule>
  <IfModule mod_env.c>
    Header set X-LiteSpeed-Cache-Control "no-cache"
  </IfModule>
</FilesMatch>

# Explicitly enable aggressive caching for static assets (images, CSS, JS, fonts, icons) to prevent reloading
<FilesMatch "\.(js|css|jpg|jpeg|gif|png|ico|pdf|txt|xml|zip|svg|woff|woff2|ttf|eot|webp)$">
  <IfModule mod_headers.c>
    Header set Cache-Control "max-age=31536000, public"
    Header unset Pragma
  </IfModule>
  <IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
  </IfModule>
</FilesMatch>
